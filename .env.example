# ==================================================
# 台灣股市每日自動抓取 - 環境變數設定
# ==================================================
# 請複製此檔案並重新命名為 .env:
#   cp .env.example .env

# Google Sheets 設定
SPREADSHEET_ID=your_spreadsheet_id_here
SHEET_NAME=工作表1

# OAuth 憑證路徑
TOKEN_PATH=/path/to/google_token.json
CLIENT_SECRET_PATH=/path/to/google_client_secret.json

# 爬取設定
YAHOO_TIMEOUT=15
EXCHANGE_TIMEOUT=10
MIN_WAIT=6
MAX_WAIT=15

# 日誌等級: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
